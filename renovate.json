{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "schedule": ["every weekend"],
  "labels": ["dependencies"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["every weekend"]
  },
  "packageRules": [
    {
      "description": "Group ratatui ecosystem updates (ratatui, ratatui-image, crossterm)",
      "matchPackageNames": ["ratatui", "ratatui-image", "crossterm"],
      "groupName": "ratatui ecosystem"
    },
    {
      "description": "Require approval for major version bumps",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Auto-merge minor and patch updates",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
